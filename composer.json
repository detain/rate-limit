{
    "type": "library",
    "name": "detain/rate-limit",
    "description": "PHP rate limiting library with Token Bucket and Leaky Bucket Algorithms, based on palepurple/rate-limit, grandson to touhonoob/rate-limit, and jeroenvisser101/LeakyBucket",
    "keywords": ["ratelimit", "throttling", "limits", "tokenbucket", "leakybucket"],
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "psr/cache": "^2|^3"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.52",
        "phpunit/phpunit": "^10.5|^11.0|^12.0",
        "predis/predis": "^2.0",
        "tedivm/stash": "^1.0",
        "phpstan/phpstan": "^1.12",
        "squizlabs/php_codesniffer": "^3.10",
        "vimeo/psalm": "^5.26"
    },
    "require-dev-tools": {
        "vimeo/psalm": ">=5.0"
    },
    "suggest": {
        "tedivm/stash": "^1.0",
        "predis/predis": "^2.0",
        "ext-redis": "Required for RedisAdapter",
        "ext-memcached": "Required for MemcachedAdapter",
        "ext-apcu": "Required for APCuAdapter"
    },
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net"
        }
    ],
    "autoload": {
        "psr-4": {
            "Detain\\RateLimit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Detain\\RateLimit\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "build": [
            "@lint",
            "@check-format",
            "@psalm",
            "@phpstan",
            "@test"
        ],
        "psalm": "@php psalm-wrapper.php",
        "phpstan": "@php vendor/bin/phpstan analyse --no-cache",
        "lint": "find src tests -name '*.php' -print0 | xargs -0 -n1 -P4 php -l -d error_reporting=24575 > /dev/null",
        "check-format": "@php ./vendor/bin/php-cs-fixer fix --ansi --dry-run --diff",
        "format": "@php ./vendor/bin/php-cs-fixer fix --ansi",
        "test": "@php ./vendor/bin/phpunit --configuration phpunit.xml.dist",
        "phpcs": "@php ./vendor/bin/phpcs --standard=PSR12 src/",
        "phpcs:fix": "@php ./vendor/bin/phpcbf --standard=PSR12 src/"
    }
}
